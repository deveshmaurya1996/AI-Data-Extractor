# Root .env consumed by docker-compose.yml variable substitution.
# Copy to .env in the repo root before running `docker compose up`.
# Per-service runtime configuration lives in backend/.env and frontend/.env.local.

# --- Postgres (matches docker-compose.yml defaults; override only if needed) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=chatbot
POSTGRES_TZ=UTC

# --- Pollinations LLM (required for the chat to produce user-facing text) ---
# The backend hard-fails on missing/invalid keys; supply a valid key before
# starting the API container, or the chat will only return error messages.
POLLINATIONS_API_KEY=
POLLINATIONS_MODEL=openai
POLLINATIONS_BASE_URL=https://gen.pollinations.ai/v1
POLLINATIONS_TIMEOUT=30
